<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TokenGenerator.UI.ViewModels"
        xmlns:views="using:TokenGenerator.UI.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="TokenGenerator.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="TokenGenerator">

	<TabControl>
		<!-- Вкладка Main -->
		<TabItem Header="Main">
			<StackPanel Margin="10">
				<TextBlock Text="Главное содержимое" />

				<Border Background="Gainsboro"
					BorderBrush="Black"
					BorderThickness="2"
					CornerRadius="3"
					Padding="10"
					Margin="0 0 0 10">
						<StackPanel  Margin="10">
							<StackPanel Orientation="Horizontal" Spacing="10">
								<Button
									Content="Generate token"
									Command="{Binding GenerateTokenCommand}"
									IsEnabled="{Binding !IsBusy}" />

								<Button
									Content="Copy token"
									Command="{Binding CopyTokenCommand}" />
							</StackPanel>

							<TextBlock
								Text="Access token:"
								MaxHeight="100"
								Margin="0,5,0,0" />

							<TextBox
								IsEnabled="False"
								Text="{Binding MaskedAccessToken}"
								Margin="0 5"
								AcceptsReturn="True"
								TextWrapping="Wrap"
								FontWeight="Bold"
								Watermark="Token will appear here..."
								IsReadOnly="True"
								Height="100" />

							<TextBlock
								Text="{Binding ExpiresOn, StringFormat='Expires: {0:G}'}"
								Margin="0,5,0,0" />

					</StackPanel>
				</Border>

			</StackPanel>
			

		</TabItem>

		<!-- Вкладка Settings -->
		<TabItem Header="Settings">
			<views:SettingsView  DataContext="{Binding SettingsViewModel}" />
		</TabItem>
	</TabControl>
</Window>